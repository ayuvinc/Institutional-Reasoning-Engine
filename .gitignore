.yarn

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── INTERNAL — LOCAL ONLY, NEVER COMMIT ───────────────────────
# Full-cost versions and working files — stay on this machine only
internal/

# ── SENSITIVE — NEVER COMMIT ──────────────────────────────────
# API keys, tokens, credentials
*.key
*.pem
*.p12
*.token
*.secret
.env.local
.env.*.local
secrets.json
secrets.yaml
secrets.yml
config.local.*
credentials.json
service_account.json

# Token maps (Cluster E — pseudonymisation)
token_map*.json
token_map*.pkl
*_token_map.*

# Case data — never in version control
case_data/
evidence/
uploads/
raw_documents/
transcripts/raw/

# Audit logs — stored in database, not files
audit_chain*.json
audit_log*.json

# Model weights — too large, use HuggingFace/Ollama instead
*.bin
*.safetensors
*.gguf
*.ggml
models/

# ── Database dumps ────────────────────────────────────────────
*.sql
*.dump
*.db
*.sqlite
*.sqlite3

# ── Docker ────────────────────────────────────────────────────
.docker/

# ── Terraform / Infrastructure ────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
